CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_rt305x=y

# Build VoCore 8M device (RT5350)
CONFIG_TARGET_ramips_rt305x_DEVICE_vocore_vocore-8m=y
CONFIG_ALL=y
CONFIG_ALL_NONSHARED=y
CONFIG_ALL_KMODS=y
# Skip Rust toolchain packages to avoid CI llvm.download-ci-llvm restriction
# CONFIG_PACKAGE_cargo is not set
# CONFIG_PACKAGE_rust is not set
# CONFIG_PACKAGE_rust-src is not set
# CONFIG_PACKAGE_rustfmt is not set